            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"30 Day Push-Up Challenge\",\n  \"description\": \"Complete 30 push-ups every day for 30 days.\",\n  \"target\": 30,\n  \"unit\": \"push-ups\",\n  \"status\": \"active\",\n  \"progress\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/challenges",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "challenges"
              ]
            }
          }
        },
        {
          "name": "Get Challenges",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/challenges?status=active&sortBy=createdAt&order=desc&limit=10&page=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "challenges"
              ],
              "query": [
                {
                  "key": "status",
